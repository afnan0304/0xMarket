# Optional base URL for health/gemini requests in deployed frontend.
# Leave empty in local dev to use relative /api calls (with Vite proxy).
VITE_API_BASE_URL=

# Assets fetch endpoint used by the store.
# Default in code is /api/assets for same-origin deployments.
# Keep this as /api/assets when frontend + backend share one domain on Vercel.
VITE_ASSETS_ENDPOINT=/api/assets
