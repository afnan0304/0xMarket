# Optional base URL for health/gemini requests in deployed frontend.
# Leave empty in local dev to use relative /api calls (with Vite proxy).
VITE_API_BASE_URL=

# Assets fetch endpoint used by the store.
# Default in code is http://localhost:5000/api/assets
# Set this in production to your hosted API endpoint, e.g.:
# VITE_ASSETS_ENDPOINT=https://your-api.onrender.com/api/assets
VITE_ASSETS_ENDPOINT=
